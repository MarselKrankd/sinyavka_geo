# --- Django ---
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
DB_NAME=sinyavka_geo
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Google Maps JavaScript API (Street View + maps) ---
# https://console.cloud.google.com -> APIs & Services -> Credentials -> Create API key
# Включи: Maps JavaScript API, Street View Static API
GOOGLE_MAPS_API_KEY=

# --- Google OAuth ---
# https://console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID (Web app)
# Redirect: http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Yandex OAuth ---
# https://oauth.yandex.ru -> Зарегистрировать новое приложение
# Redirect: http://localhost:8000/accounts/yandex/login/callback/
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- VK OAuth ---
# https://vk.com/apps?act=manage -> Создать приложение -> Веб-сайт
# Site: http://localhost:8000, Redirect: http://localhost:8000/accounts/vk/login/callback/
VK_CLIENT_ID=
VK_CLIENT_SECRET=
