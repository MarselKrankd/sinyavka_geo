# --- Django ---
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
DB_NAME=sinyavka_geo
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Yandex Maps JavaScript API (карта + панорамы) ---
# Получить тут: https://developer.tech.yandex.ru/
# Бесплатно, без оплаты. Тот же ключ работает и для карты, и для панорам.
YANDEX_MAPS_API_KEY=

# --- Yandex OAuth ---
# https://oauth.yandex.ru -> Зарегистрировать новое приложение
# Redirect: http://localhost:8000/accounts/yandex/login/callback/
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
